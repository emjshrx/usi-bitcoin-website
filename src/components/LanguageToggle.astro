---
import { withBase } from "../utils/withBase";

interface Props {
  lang: "it" | "en";
  label: string;
}

const { lang, label } = Astro.props;
const href = lang === "it" ? withBase("en/") : withBase("");
const hrefLang = lang === "it" ? "en" : "it";
---

<a
  href={href}
  hreflang={hrefLang}
  lang={hrefLang}
  class="inline-flex min-h-[40px] items-center justify-center rounded-sm border border-ink/25 bg-card px-4 py-2 text-xs font-semibold uppercase tracking-wide text-ink shadow-sm transition hover:border-ink hover:bg-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink md:text-sm"
>
  {label}
</a>
