---
interface Props {
  url: string;
  label: string;
}

const { url, label } = Astro.props;

const u = url.toLowerCase();
const l = label.toLowerCase();

type Network =
  | "instagram"
  | "x"
  | "linkedin"
  | "youtube"
  | "facebook"
  | "github"
  | "telegram"
  | "spotify"
  | "tiktok"
  | "generic";

let network: Network = "generic";
if (u.includes("instagram") || l.includes("instagram")) network = "instagram";
else if (
  u.includes("twitter.com") ||
  u.includes("x.com") ||
  l.includes("twitter") ||
  /^x\b/.test(l)
)
  network = "x";
else if (u.includes("linkedin") || l.includes("linkedin")) network = "linkedin";
else if (u.includes("youtube") || u.includes("youtu.be") || l.includes("youtube"))
  network = "youtube";
else if (u.includes("facebook") || u.includes("fb.com") || l.includes("facebook"))
  network = "facebook";
else if (u.includes("github") || l.includes("github")) network = "github";
else if (u.includes("t.me") || u.includes("telegram") || l.includes("telegram"))
  network = "telegram";
else if (u.includes("spotify") || l.includes("spotify")) network = "spotify";
else if (u.includes("tiktok") || l.includes("tiktok")) network = "tiktok";
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  class="group inline-flex h-11 w-11 items-center justify-center rounded-full text-ink/70 transition hover:bg-accent hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
>
