---
import Layout from "../layouts/Layout.astro";
import ContentCard from "./ContentCard.astro";
import SectionBlock from "./SectionBlock.astro";
import SocialIconLink from "./SocialIconLink.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { withBase } from "../utils/withBase";
import type { SiteData } from "../data/siteData";

interface Props {
  site: SiteData;
  lang: "it" | "en";
}

const { site, lang } = Astro.props;
const asset = withBase;

const {
  brand,
  report,
  cosaFacciamo,
  chiSiamo,
  missione,
  visione,
  join,
  social,
  joinTeam,
  partners,
  team,
  seo,
  ui,
} = site;

const showReport = Boolean(report.url?.trim());
const showCosaFacciamo =
  cosaFacciamo.events.length > 0 || Boolean(cosaFacciamo.intro?.trim());
const showSocial = social.links.length > 0;
const showJoinTeam = Boolean(joinTeam.url?.trim());
const showPartners = partners.items.length > 0;
const showTeam = team.members.length > 0;
---

<Layout title={brand.title} description={seo.description} lang={lang}>
  <header class="relative overflow-hidden bg-card px-6 py-6 md:py-8">
    <div class="absolute right-4 top-4 z-20 md:right-6 md:top-6">
      <LanguageToggle lang={lang} label={ui.languageSwitchLabel} />
    </div>
    <div
      class="hero-diagonal-tl pointer-events-none absolute left-0 top-0 h-32 w-48 bg-accent md:h-40 md:w-72"
      aria-hidden="true"
    >
    </div>
    <div
      class="hero-diagonal-br pointer-events-none absolute bottom-0 right-0 h-36 w-56 bg-accent md:h-48 md:w-80"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto flex max-w-lg flex-col items-center text-center">
      <img
        src={asset(site.images.logo)}
        alt={ui.logoAlt}
        width="96"
        height="96"
        class="mb-4 h-20 w-20 object-contain md:h-24 md:w-24"
      />
      <h1 class="text-xl font-bold tracking-tight md:text-2xl">{brand.title}</h1>
    </div>
  </header>

  <main class="px-4 pb-16 pt-8 md:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl space-y-12">
      <section
        class="scroll-mt-6"
        aria-label={`${brand.title} — ${chiSiamo.title}`}
      >
        <div class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-12 lg:gap-8 lg:items-stretch">
          <div class="flex flex-col gap-4 lg:col-span-4">
            {
              showReport ? (
                <section
                  id="report"
                  class="scroll-mt-6 flex flex-1 flex-col rounded-sm border border-ink/10 bg-card p-6 shadow-card md:p-7"
                  aria-labelledby="report-heading"
                >
                  <h2 id="report-heading" class="mb-3 text-lg font-bold md:text-xl">
                    {report.sectionTitle}
                  </h2>
                  {
                    report.coverImage?.trim() ? (
                      <a
                        href={report.url}
                        class="mb-4 block overflow-hidden rounded-sm border border-ink/10 shadow-sm transition hover:opacity-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${report.buttonLabel} — PDF`}
                      >
                        <img
                          src={asset(report.coverImage.trim())}
                          alt={ui.reportCoverAlt}
                          width="420"
                          height="594"
                          class="aspect-[210/297] w-full object-cover object-top"
                          loading="lazy"
                        />
                      </a>
                    ) : null
                  }
                  <p class="mb-5 flex-1 text-[0.95rem] leading-relaxed text-ink/85">{report.description}</p>
                  <a
                    href={report.url}
                    class="inline-flex min-h-[44px] items-center justify-center rounded-sm border-2 border-ink bg-ink px-5 py-3 text-sm font-semibold text-card transition hover:bg-card hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {report.buttonLabel}
                  </a>
                </section>
              ) : (
                <div class="hidden lg:block" aria-hidden="true" />
              )
            }
          </div>

          <div class="flex flex-col gap-4 lg:col-span-4">
            <ContentCard title={chiSiamo.title}>
              <p>{chiSiamo.body}</p>
            </ContentCard>
            <ContentCard title={missione.title}>
              <p>{missione.body}</p>
            </ContentCard>
            <ContentCard title={visione.title}>
              <p>{visione.body}</p>
            </ContentCard>
          </div>

          <div class="flex flex-col gap-5 lg:col-span-4">
            {
              showSocial ? (
                <section
                  id="social"
                  class="scroll-mt-6 rounded-sm border border-ink/10 bg-card p-6 shadow-card md:p-7"
                  aria-label={social.sectionTitle}
                >
                  <p class="mb-1 text-sm font-semibold uppercase tracking-wide text-ink/70">
                    {social.sectionTitle}
                  </p>
                  {social.intro ? <p class="mb-4 text-[0.9rem] text-ink/75">{social.intro}</p> : null}
                  <ul class="flex flex-wrap gap-2 sm:gap-3">
                    {social.links.map((link) => (
                      <li>
                        <SocialIconLink url={link.url} label={link.label} />
                      </li>
                    ))}
                  </ul>
                </section>
              ) : null
            }
            <section class="rounded-sm border border-ink/10 bg-card p-6 shadow-card md:p-7">
              <h2 class="mb-4 text-xl font-bold italic tracking-tight">{join.title}</h2>
              <div
                class="flex flex-col items-stretch gap-4"
              >
                {join.qrImage ? (
                  <div class="flex justify-center">
                    <img
                      src={asset(join.qrImage)}
                      alt={ui.qrAlt}
                      width="200"
                      height="200"
                      class="h-32 w-32 object-contain"
                      loading="lazy"
                    />
                  </div>
                ) : null}
                <a
                  href={join.joinUrl}
                  class="inline-flex min-h-[44px] w-full items-center justify-center rounded-sm bg-ink px-5 py-3 text-sm font-semibold text-card transition hover:bg-ink/85 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
                  rel="noopener noreferrer"
                >
                  {join.joinButtonLabel}
                </a>
                {join.email ? (
                  <a
                    href={`mailto:${join.email}`}
                    class="break-all text-center text-sm font-medium underline underline-offset-2"
                  >
                    {join.email}
                  </a>
                ) : null}
              </div>
            </section>
          </div>
        </div>
      </section>

      {
        showCosaFacciamo ? (
          <SectionBlock id="cosa-facciamo" title={cosaFacciamo.sectionTitle}>
            {cosaFacciamo.intro ? <p class="mb-6 max-w-3xl">{cosaFacciamo.intro}</p> : null}
            {cosaFacciamo.events.length > 0 ? (
              <ul class="grid gap-4 sm:grid-cols-2">
                {cosaFacciamo.events.map((ev) => (
                  <li class="overflow-hidden rounded-sm border border-ink/10 bg-card shadow-card">
                    {ev.image?.trim() ? (
                      <img
                        src={asset(ev.image.trim())}
                        alt=""
                        width="640"
                        height="360"
                        class="tear-bottom aspect-video w-full object-cover"
                        loading="lazy"
                      />
                    ) : null}
                    <div class="p-5">
                      <p class="font-bold">{ev.title}</p>
                      {ev.date ? <p class="mt-1 text-sm text-ink/65">{ev.date}</p> : null}
                      {ev.description ? <p class="mt-2 text-[0.9rem] leading-relaxed">{ev.description}</p> : null}
                    </div>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="max-w-3xl text-[0.95rem] text-ink/55">
                {ui.emptyEventsBefore}
                <code class="rounded bg-accent px-1 py-0.5 text-[0.8rem]">{ui.emptyEventsField}</code>
                {ui.emptyEventsIn}
                <code class="rounded bg-accent px-1 py-0.5 text-[0.8rem]">{ui.emptyEventsFile}</code>
                {ui.emptyEventsAfter}
              </p>
            )}
          </SectionBlock>
        ) : null
      }

      {
        showPartners ? (
          <SectionBlock id="partner" title={partners.sectionTitle}>
            {partners.intro ? <p class="mb-6 max-w-3xl">{partners.intro}</p> : null}
            <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {partners.items.map((p) => (
                <li class="flex flex-col items-center justify-center rounded-sm border border-ink/10 bg-card p-5 text-center shadow-card">
                  {p.logo?.trim() ? (
                    <img
                      src={asset(p.logo.trim())}
                      alt=""
                      class="mb-3 h-14 w-auto max-w-full object-contain"
                      loading="lazy"
                    />
                  ) : null}
                  {p.url?.trim() ? (
                    <a
                      href={p.url}
                      class="font-semibold underline-offset-2 hover:underline"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {p.name}
                    </a>
                  ) : (
                    <span class="font-semibold">{p.name}</span>
                  )}
                </li>
              ))}
            </ul>
          </SectionBlock>
        ) : null
      }

      {
        showJoinTeam ? (
          <SectionBlock id="join-club" title={joinTeam.sectionTitle} centerHeading>
            <div class="mx-auto flex max-w-2xl flex-col items-center text-center">
              <p class="mb-5">{joinTeam.description}</p>
              <a
                href={joinTeam.url}
                class="inline-flex min-h-[44px] items-center justify-center rounded-sm bg-ink px-5 py-3 text-sm font-semibold text-card transition hover:bg-ink/85 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
                target="_blank"
                rel="noopener noreferrer"
              >
                {joinTeam.buttonLabel}
              </a>
            </div>
          </SectionBlock>
        ) : null
      }

      {
        showTeam ? (
          <SectionBlock id="team" title={team.sectionTitle}>
            {team.intro ? <p class="mb-8 mx-auto max-w-3xl text-center">{team.intro}</p> : null}
            <ul class="mx-auto grid max-w-5xl grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-6 justify-items-center text-center">
              {team.members.map((m) => (
                <li class="flex w-full max-w-[7.5rem] flex-col items-center">
                  {m.photo?.trim() ? (
                    <img
                      src={asset(m.photo.trim())}
                      alt=""
                      width="120"
                      height="120"
                      class="mb-2 h-20 w-20 rounded-full object-cover md:h-[4.5rem] md:w-[4.5rem]"
                      loading="lazy"
                    />
                  ) : (
                    <div
                      class="mb-2 flex h-20 w-20 items-center justify-center rounded-full bg-accent text-sm font-bold text-ink/40 md:h-[4.5rem] md:w-[4.5rem]"
                      aria-hidden="true"
                    >
                      {m.name
                        .split(/\s+/)
                        .map((w) => w[0])
                        .join("")
                        .slice(0, 2)
                        .toUpperCase()}
                    </div>
                  )}
                  <p class="text-sm font-bold leading-tight">{m.name}</p>
                  {m.role ? <p class="mt-1 text-xs font-medium text-ink/70">{m.role}</p> : null}
                  {m.linkedinUrl?.trim() ? (
                    <a
                      href={m.linkedinUrl.trim()}
                      class="mt-2 text-xs font-semibold underline underline-offset-2"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {ui.linkedinLabel}
                    </a>
                  ) : null}
                </li>
              ))}
            </ul>
          </SectionBlock>
        ) : null
      }
    </div>
  </main>

  <footer class="border-t border-ink/10 bg-card px-4 py-8 text-center text-sm text-ink/65 md:px-6">
    <p>{ui.copyrightNotice}</p>
  </footer>
</Layout>
