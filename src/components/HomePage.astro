---
import Layout from "../layouts/Layout.astro";
import SocialIconLink from "./SocialIconLink.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { withBase } from "../utils/withBase";
import type { SiteData } from "../data/siteData";

interface Props {
  site: SiteData;
  lang: "it" | "en";
}

const { site, lang } = Astro.props;
const asset = withBase;
const en = lang === "en";

const {
  brand,
  report,
  cosaFacciamo,
  chiSiamo,
  missione,
  visione,
  join,
  social,
  joinTeam,
  partners,
  team,
  seo,
  ui,
} = site;

const showReport = Boolean(report.url?.trim());
const showCosaFacciamo = cosaFacciamo.events.length > 0 || Boolean(cosaFacciamo.intro?.trim());
const showSocial = social.links.length > 0;
const showJoinTeam = Boolean(joinTeam.url?.trim());
const showPartners = partners.items.length > 0;
const showTeam = team.members.length > 0;

const heroImage = site.images.hero?.trim() ? asset(site.images.hero.trim()) : null;

// Filter out YouTube from social links
const filteredSocialLinks = social.links.filter(
  (link) => !link.label.toLowerCase().includes("youtube") && !link.url?.toLowerCase().includes("youtube")
);
---

<Layout title={brand.title} description={seo.description} lang={lang}>

  <!-- ═══ HEADER BANNER — logo only, white, scrolls away ════════════════ -->
  <header class="bg-white px-4 py-4 md:px-8">
    <div class="mx-auto flex max-w-7xl items-center justify-between">
      <a href={asset("")} aria-label={ui.logoAlt}>
        <img
          src={asset(site.images.logo)}
          alt={ui.logoAlt}
          width="52"
          height="52"
          class="h-13 w-13 rounded-full object-cover"
        />
      </a>
      <LanguageToggle lang={lang} label={ui.languageSwitchLabel} />
    </div>
  </header>

  <!-- ═══ STICKY MENU BAR ════════════════════════════════════════════════ -->
  <nav class="sticky top-0 z-50 border-b border-black/8 bg-white/95 backdrop-blur-md">
    <div class="mx-auto flex max-w-7xl items-center gap-1 overflow-x-auto px-4 py-2.5 md:gap-2 md:px-8">
      <a href="#chi-siamo" class="whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-semibold text-ink/60 transition hover:bg-gray-100 hover:text-ink">
        {chiSiamo.title}
      </a>
      <a href="#cosa-facciamo" class="whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-semibold text-ink/60 transition hover:bg-gray-100 hover:text-ink">
        {cosaFacciamo.sectionTitle}
      </a>
      {showTeam && (
        <a href="#team" class="whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-semibold text-ink/60 transition hover:bg-gray-100 hover:text-ink">
          {team.sectionTitle}
        </a>
      )}
      {showPartners && (
        <a href="#partner" class="whitespace-nowrap rounded-full px-3 py-1.5 text-sm font-semibold text-ink/60 transition hover:bg-gray-100 hover:text-ink">
          {partners.sectionTitle}
        </a>
      )}
      <span class="flex-1"></span>
      <span aria-hidden="true" class="shrink-0 text-base leading-none">🇨🇭</span>
      {join.joinUrl && (
        <a
          href={join.joinUrl}
          class="ml-2 shrink-0 whitespace-nowrap rounded-full bg-orange-500 px-4 py-1.5 text-sm font-bold text-white transition hover:bg-orange-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
          rel="noopener noreferrer"
        >
          {join.joinButtonLabel}
        </a>
      )}
    </div>
  </nav>

  <!-- ═══ HERO ════════════════════════════════════════════════════════════ -->
  <section
    class="relative flex items-end overflow-hidden"
    style="min-height: 72vh;"
    aria-label={brand.title}
  >
    <!-- Parallax background -->
    <div
      id="hero-bg"
      class="absolute left-0 right-0 will-change-transform"
      style={`top: -40%; height: 180%; ${heroImage ? `background: url('${heroImage}') center/cover no-repeat;` : "background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 50%, #1a365d 100%);"}`}
      aria-hidden="true"
    >
      <div class="absolute inset-0 bg-black/45"></div>
    </div>

    <!-- Bottom fade to white -->
    <div
      class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-white to-transparent"
      aria-hidden="true"
    ></div>

    <!-- Hero text -->
    <div class="relative z-10 w-full px-6 pb-20 md:px-16">
      <h1 class="text-6xl font-black uppercase leading-none tracking-tight text-white drop-shadow-xl md:text-8xl lg:text-9xl">
        {brand.title}
      </h1>
      <p class="mt-4 text-base font-semibold tracking-wide text-white/65 drop-shadow md:text-lg">
        {en
          ? "First Bitcoin University Club in Switzerland · USI · Lugano"
          : "Primo Bitcoin University Club in Svizzera · USI · Lugano"}
      </p>
    </div>
  </section>

  <!-- ═══ LIGHT SECTION ═══════════════════════════════════════════════════ -->
  <div class="bg-white">

    <!-- CHI SIAMO + MISSIONE + VISIONE — merged ──────────────────────── -->
    <section id="chi-siamo" class="scroll-mt-12 px-4 py-20 md:px-8">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 text-3xl font-black tracking-tight text-ink md:text-4xl">
          {chiSiamo.title}
        </h2>
        <p class="text-lg leading-relaxed text-ink/70">
          {chiSiamo.body} {missione.body} {visione.body}
        </p>
      </div>
    </section>

    <!-- COSA FACCIAMO ────────────────────────────────────────────────── -->
    {showCosaFacciamo && (
      <section id="cosa-facciamo" class="scroll-mt-12 bg-gray-50 px-4 py-20 md:px-8">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-12 text-3xl font-black tracking-tight text-ink md:text-4xl">
            {cosaFacciamo.sectionTitle}
          </h2>
          {cosaFacciamo.intro && (
            <p class="mb-10 max-w-2xl text-sm text-ink/60">{cosaFacciamo.intro}</p>
          )}
          {cosaFacciamo.events.length > 0 && (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
              {cosaFacciamo.events.map((ev) => (
                <article class="flex flex-col overflow-hidden rounded-xl bg-white shadow-card">
                  {ev.image?.trim() ? (
                    <img
                      src={asset(ev.image.trim())}
                      alt=""
                      width="480"
                      height="270"
                      class="aspect-video w-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="aspect-video w-full bg-slate-800 flex items-center justify-center" aria-hidden="true">
                      <span class="text-white/10 text-5xl font-black">₿</span>
                    </div>
                  )}
                  <div class="flex flex-1 flex-col p-5">
                    <p class="font-bold text-ink">{ev.title}</p>
                    {ev.date && <p class="mt-1 text-xs text-ink/45">{ev.date}</p>}
                    {ev.description && (
                      <p class="mt-2 flex-1 text-[0.85rem] leading-relaxed text-ink/70">{ev.description}</p>
                    )}
                    <span class="mt-4 text-sm font-bold text-orange-500">
                      {en ? "Learn more →" : "Scopri di più →"}
                    </span>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

  </div><!-- /light section -->

  <!-- ═══ DARK SECTION ════════════════════════════════════════════════════ -->
  <div class="bg-black text-white">

    <!-- MISSION QUOTE ──────────────────────────────────────────────────── -->
    <section class="px-6 py-24 md:px-16">
      <div class="mx-auto max-w-4xl">
        <blockquote class="text-2xl font-bold italic leading-snug text-white/85 md:text-4xl">
          &ldquo;{missione.body}&rdquo;
        </blockquote>
      </div>
    </section>

    <!-- WAYS WE DO COMMUNITY ────────────────────────────────────────────── -->
    {showCosaFacciamo && cosaFacciamo.events.length > 0 && (
      <section class="px-4 py-16 md:px-8">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-12 text-4xl font-black uppercase leading-tight tracking-tight text-white md:text-6xl">
            {en
              ? <><span>WAYS </span><span class="bg-white px-2 text-black">[WE DO]</span><span> COMMUNITY</span></>
              : <><span>MODI </span><span class="bg-white px-2 text-black">[CHE USIAMO]</span><span> COMUNITÀ</span></>}
          </h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {cosaFacciamo.events.map((ev) => (
              <article class="flex flex-col rounded-xl border border-white/10 bg-white/5 p-6 transition hover:border-orange-500/50">
                <span class="mb-4 inline-block self-start rounded-full bg-orange-500 px-3 py-1 text-xs font-bold uppercase tracking-widest text-white">
                  {ev.title}
                </span>
                {ev.date && <p class="mb-2 text-xs text-white/40">{ev.date}</p>}
                {ev.description && (
                  <p class="flex-1 text-[0.9rem] leading-relaxed text-white/65">{ev.description}</p>
                )}
                <span class="mt-5 text-sm font-bold text-orange-400">
                  {en ? "Learn More →" : "Scopri →"}
                </span>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- TEAM ─────────────────────────────────────────────────────────── -->
    {showTeam && (
      <section id="team" class="scroll-mt-12 px-4 py-20 md:px-8">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-4 text-3xl font-black tracking-tight text-white md:text-4xl">
            {team.sectionTitle}
          </h2>
          {team.intro && (
            <p class="mb-12 max-w-2xl text-sm text-white/50">{team.intro}</p>
          )}
          <ul class="grid grid-cols-2 gap-5 sm:grid-cols-3 md:grid-cols-6">
            {team.members.map((m) => (
              <li class="flex flex-col items-center rounded-xl bg-white/5 p-5 text-center">
                {m.photo?.trim() ? (
                  <img
                    src={asset(m.photo.trim())}
                    alt=""
                    width="120"
                    height="120"
                    class="mb-3 h-16 w-16 rounded-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="mb-3 flex h-16 w-16 items-center justify-center rounded-full bg-white/10 text-sm font-bold text-white/40"
                    aria-hidden="true"
                  >
                    {m.name.split(/\s+/).map((w: string) => w[0]).join("").slice(0, 2).toUpperCase()}
                  </div>
                )}
                <p class="text-sm font-bold leading-tight text-white">{m.name}</p>
                {m.role && <p class="mt-1 text-xs text-white/55">{m.role}</p>}
                {m.linkedinUrl?.trim() && (
                  <a
                    href={m.linkedinUrl.trim()}
                    class="mt-2 text-xs font-semibold text-orange-400 underline underline-offset-2 hover:text-orange-300"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {ui.linkedinLabel}
                  </a>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- PARTNERS ─────────────────────────────────────────────────────── -->
    {showPartners && (
      <section id="partner" class="scroll-mt-12 px-4 py-16 md:px-8">
        <div class="mx-auto max-w-6xl">
          <p class="mb-8 text-xs font-bold uppercase tracking-widest text-white/35">{partners.sectionTitle}</p>
          {partners.intro && <p class="mb-8 text-sm text-white/50">{partners.intro}</p>}
          <ul class="grid grid-cols-2 gap-5 sm:grid-cols-4">
            {partners.items.map((p) => (
              <li class="flex items-center justify-center rounded-xl border border-white/10 bg-white/5 p-6 transition hover:border-orange-500/40">
                {p.logo?.trim() ? (
                  p.url?.trim() ? (
                    <a href={p.url} target="_blank" rel="noopener noreferrer" aria-label={p.name}>
                      <img
                        src={asset(p.logo.trim())}
                        alt={p.name}
                        class="h-10 w-auto max-w-full object-contain brightness-0 invert opacity-70 transition hover:opacity-100"
                        loading="lazy"
                      />
                    </a>
                  ) : (
                    <img
                      src={asset(p.logo.trim())}
                      alt={p.name}
                      class="h-10 w-auto max-w-full object-contain brightness-0 invert opacity-70"
                      loading="lazy"
                    />
                  )
                ) : (
                  p.url?.trim() ? (
                    <a href={p.url} class="text-sm font-semibold text-white/70 hover:text-white" target="_blank" rel="noopener noreferrer">{p.name}</a>
                  ) : (
                    <span class="text-sm font-semibold text-white/70">{p.name}</span>
                  )
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- JOIN + SOCIAL ───────────────────────────────────────────────── -->
    <section class="px-4 py-20 md:px-8">
      <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-2">

        <!-- Join: title + button only (no QR, no email) -->
        <div class="flex flex-col items-start gap-6">
          <h2 class="text-2xl font-black tracking-tight text-white">{join.title}</h2>
          <a
            href={join.joinUrl}
            class="inline-flex min-h-[44px] items-center justify-center rounded-full bg-orange-500 px-6 py-3 text-sm font-bold text-white transition hover:bg-orange-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
            rel="noopener noreferrer"
          >
            {join.joinButtonLabel}
          </a>
        </div>

        <!-- Social: icons (no YouTube) + email below -->
        {(filteredSocialLinks.length > 0 || join.email) && (
          <div class="flex flex-col gap-5">
            {filteredSocialLinks.length > 0 && (
              <>
                <p class="text-xs font-bold uppercase tracking-widest text-white/35">{social.sectionTitle}</p>
                {social.intro && <p class="text-[0.9rem] text-white/55">{social.intro}</p>}
                <ul class="flex flex-wrap gap-2">
                  {filteredSocialLinks.map((link) => (
                    <li>
                      <SocialIconLink url={link.url} label={link.label} dark={true} />
                    </li>
                  ))}
                </ul>
              </>
            )}
            {join.email && (
              <a
                href={`mailto:${join.email}`}
                class="break-all text-sm font-medium text-white/50 underline underline-offset-2 transition hover:text-white/80"
              >
                {join.email}
              </a>
            )}
          </div>
        )}

      </div>
    </section>

    <!-- JOIN TEAM CTA ───────────────────────────────────────────────── -->
    {showJoinTeam && (
      <section class="px-4 py-16 text-center md:px-8">
        <div class="mx-auto max-w-2xl">
          <h2 class="mb-4 text-3xl font-black tracking-tight text-white md:text-4xl">{joinTeam.sectionTitle}</h2>
          {joinTeam.description && (
            <p class="mb-8 text-[0.95rem] leading-relaxed text-white/60">{joinTeam.description}</p>
          )}
          <a
            href={joinTeam.url}
            class="inline-flex min-h-[48px] items-center justify-center rounded-full bg-orange-500 px-8 py-3 text-sm font-bold text-white transition hover:bg-orange-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
            target="_blank"
            rel="noopener noreferrer"
          >
            {joinTeam.buttonLabel}
          </a>
        </div>
      </section>
    )}

    <!-- REPORT ─────────────────────────────────────────────────────── -->
    {showReport && (
      <section class="px-4 pb-20 pt-8 md:px-8">
        <div class="mx-auto max-w-6xl">
          <h2 class="mb-4 text-2xl font-black tracking-tight text-white">{report.sectionTitle}</h2>
          {report.description && (
            <p class="mb-6 text-sm text-white/55">{report.description}</p>
          )}
          <a
            href={report.url}
            class="inline-flex min-h-[44px] items-center justify-center rounded-full border-2 border-white px-6 py-3 text-sm font-bold text-white transition hover:bg-white hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
            target="_blank"
            rel="noopener noreferrer"
          >
            {report.buttonLabel}
          </a>
        </div>
      </section>
    )}

    <!-- FOOTER ─────────────────────────────────────────────────────── -->
    <footer class="border-t border-white/10 px-4 py-8 text-center">
      <p class="text-xs text-white/30">{ui.copyrightNotice}</p>
    </footer>

  </div><!-- /dark section -->

</Layout>

<script is:inline>
  (function () {
    var el = document.getElementById('hero-bg');
    if (!el) return;
    var ticking = false;
    function update() {
      el.style.transform = 'translateY(' + (window.scrollY * 0.35) + 'px)';
      ticking = false;
    }
    window.addEventListener('scroll', function () {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>
