---
import { withBase } from "../utils/withBase";

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = "it" } = Astro.props;
const canonical =
  Astro.site != null
    ? new URL(Astro.url.pathname, Astro.site).href
    : Astro.url.href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/jpeg" href={withBase("images/pos_hub_logo.jpeg")} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={String(canonical)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;0,700;1,600;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-page font-sans text-ink antialiased">
    <slot />
  </body>
</html>

